static char* FloatToStrInt(float val) {
    static char buf[16];
    int int_part = (int)val;
    int dec_part = (int)((val - int_part) * 10);
    if (dec_part < 0) dec_part = -dec_part;
    if (val < 0 && int_part == 0) {
        sprintf(buf, "-0.%d", dec_part);
    } else {
        sprintf(buf, "%d.%d", int_part, dec_part);
    }
    return buf;
}

